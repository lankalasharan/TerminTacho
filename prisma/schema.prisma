generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  hasSubmittedTimeline Boolean   @default(false)
  timelineSubmittedAt  DateTime?
  lastIpAddress        String?
  createdAt            DateTime  @default(now())
  accounts             Account[]
  sessions             Session[]
  votes                Vote[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Office {
  id        String   @id @default(cuid())
  city      String
  name      String
  address   String?
  phone     String?
  website   String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  reports   Report[]
  reviews   Review[]
}

model ProcessType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id              String        @id @default(cuid())
  officeId        String
  processTypeId   String
  caseNumber      String?
  method          String
  submittedAt     DateTime
  decisionAt      DateTime?
  status          String
  notes           String?
  userEmail       String?
  userId          String?
  ipAddress       String?
  isOfficial      Boolean       @default(false)
  createdAt       DateTime      @default(now())
  helpful         Int           @default(0)
  notHelpful      Int           @default(0)
  confidenceScore Float         @default(0.5)
  isStillWaiting  Boolean       @default(false)
  // Trust system fields
  trustLevel      String        @default("unverified") // "unverified" | "verified" | "community_verified" | "admin_digest"
  matchCount      Int           @default(0)            // "Matches my experience" count
  sentiment       String?                              // "fast" | "average" | "slow" quick pulse
  isAdminSeeded   Boolean       @default(false)
  sourceUrl       String?                              // source link for admin-seeded reports
  adminNote       String?                              // admin's context note
  // Reminder email opt-in (GDPR)
  reminderOptIn   Boolean       @default(false)
  reminderSentAt  DateTime?
  office          Office        @relation(fields: [officeId], references: [id])
  processType     ProcessType   @relation(fields: [processTypeId], references: [id])
  reportMatches   ReportMatch[]

  @@unique([userId, caseNumber, processTypeId])
  @@index([officeId, processTypeId])
  @@index([createdAt])
  @@index([userId])
  @@index([confidenceScore])
  @@index([trustLevel])
}

model ReportMatch {
  id          String   @id @default(cuid())
  reportId    String
  tokenHash   String   // hashed session/cookie token — no PII stored
  createdAt   DateTime @default(now())
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, tokenHash])
  @@index([reportId])
}

model Review {
  id             String    @id @default(cuid())
  officeId       String
  userId         String?
  userEmail      String?
  ipAddress      String?
  overallRating  Int
  serviceRating  Int?
  staffRating    Int?
  speedRating    Int?
  title          String?
  content        String
  processType    String?
  helpful        Int       @default(0)
  notHelpful     Int       @default(0)
  createdAt      DateTime  @default(now())
  lastReviewDate DateTime?
  office         Office    @relation(fields: [officeId], references: [id])

  @@index([officeId])
  @@index([createdAt])
  @@index([userId])
}

model Vote {
  id         String         @id @default(cuid())
  userId     String
  targetType VoteTargetType
  targetId   String
  helpful    Boolean
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Newsletter {
  id             String    @id @default(cuid())
  email          String    @unique
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([subscribedAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model ConsentLog {
  id          String   @id @default(cuid())
  action      String
  consentType String   @default("cookies")
  maskedIp    String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([consentType])
}

enum VoteTargetType {
  report
  review
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  reason      String?
  snapshot    Json?
  createdAt   DateTime @default(now())

  @@index([entityId])
  @@index([performedBy])
  @@index([createdAt])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  category    String
  readTime    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  autoGenerated Boolean @default(false)

  @@index([publishedAt])
  @@index([slug])
}
