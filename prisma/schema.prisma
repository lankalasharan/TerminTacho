generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  hasSubmittedTimeline  Boolean   @default(false)
  timelineSubmittedAt   DateTime?
  lastIpAddress         String?   // Track IP for fraud detection
  createdAt             DateTime  @default(now())
  accounts              Account[]
  sessions              Session[]
  votes                 Vote[]
}

enum VoteTargetType {
  report
  review
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Office {
  id        String   @id @default(cuid())
  city      String
  name      String
  address   String?
  phone     String?
  website   String?
  createdAt DateTime @default(now())
  reports   Report[]
  reviews   Review[]
}

model ProcessType {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id                String      @id @default(cuid())
  officeId          String
  processTypeId     String
  caseNumber        String?     // For duplicate detection
  method            String
  submittedAt       DateTime
  decisionAt        DateTime?
  status            String
  notes             String?
  userEmail         String?
  userId            String?
  ipAddress         String?     // Track IP for fraud detection
  isOfficial        Boolean     @default(false) // Official baseline data
  createdAt         DateTime    @default(now())
  helpful           Int         @default(0)
  notHelpful        Int         @default(0)
  confidenceScore   Float       @default(0.5)  // 0-1 scale based on account age
  isStillWaiting    Boolean     @default(false) // Community update
  office            Office      @relation(fields: [officeId], references: [id])
  processType       ProcessType @relation(fields: [processTypeId], references: [id])

  @@unique([userId, caseNumber, processTypeId])  // Prevent duplicate submissions
  @@index([officeId, processTypeId])
  @@index([createdAt])
  @@index([userId])
  @@index([confidenceScore])
}

model Review {
  id              String   @id @default(cuid())
  officeId        String
  userId          String?
  userEmail       String?
  ipAddress       String?  // Track IP for fraud detection
  overallRating   Int      // 1-5 stars
  serviceRating   Int?     // 1-5 stars
  staffRating     Int?     // 1-5 stars
  speedRating     Int?     // 1-5 stars
  title           String?
  content         String   @db.Text
  processType     String?
  helpful         Int      @default(0)
  notHelpful      Int      @default(0)
  createdAt       DateTime @default(now())
  lastReviewDate   DateTime? // Track rate limiting
  office          Office   @relation(fields: [officeId], references: [id])

  @@index([officeId])
  @@index([createdAt])
  @@index([userId])
}

model Vote {
  id         String         @id @default(cuid())
  userId     String
  targetType VoteTargetType
  targetId   String
  helpful    Boolean
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
  createdAt    DateTime @default(now())

  @@index([subscribedAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
